#db
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=proxy_user
DB_PASS=proxy_secret
DB_NAME=udp_proxy_db

#jwt
JWT_SECRET=72b0e60c9af94c5f1046ba060d93549c24de9dd11d0cb44677e340aba26da5d3
JWT_EXPIRES_IN=24h

#server
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

#https — set USE_HTTPS=true and point to real certs for production
#generate a self-signed cert for dev: openssl req -x509 -newkey rsa:2048 -keyout certs/key.pem -out certs/cert.pem -days 365 -nodes -subj "/CN=localhost"
USE_HTTPS=false
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem
